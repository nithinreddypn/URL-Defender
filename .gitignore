# --- Git Ignore Rules ---

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
backend/storage/logs/*.log

# Dependencies
node_modules/
frontend/node_modules/
backend/vendor/

# Output / Bundles
dist/
frontend/dist/
dist-ssr
.output
.vinxi
.tanstack/**
.nitro

# Environment Files
.env
.env.*
!.env.example
backend/.env
frontend/.env
frontend/.env.development
frontend/.env.production
frontend/.env.example

# IDEs / OS files
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Uploads
backend/public/uploads/*
!backend/public/uploads/.gitkeep
